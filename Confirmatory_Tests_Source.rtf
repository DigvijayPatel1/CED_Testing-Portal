dSpecimens,\n  \\};\n\\};\n\nexport default calculateResult;\n\n\\par\n\\par\\par\\b File: src/utils/calculations/paverBlockCalc.js\\b0\\par\nimport STANDARDS from "../../data/standards.js";\\par\n\\par\nconst calculateResult = (testId, inputs) => \\{\\par\n  const standard = STANDARDS[testId];\\par\n\\par\n  const \\{ commonData, specimens \\} = inputs;\\par\n  const grade = commonData?.grade || "";\\par\n  const fck = parseInt(grade.replace(/\\\\D/g, ""), 10) || 0;\\par\n  const stdDev = parseFloat(commonData?.stdDeviation || 5);\\par\n\\par\n  const area = parseFloat(commonData?.planArea || 0);\\par\n  const thickness = parseFloat(commonData?.thickness || 0);\\par\n\\par\n  let ageOfSpecimen = null;\\par\n  const \\{ dateCasting, dateTesting \\} = commonData || \\{\\};\\par\n  if (dateCasting && dateTesting) \\{\\par\n    ageOfSpecimen = Math.round(\\par\n      (new Date(dateTesting) - new Date(dateCasting)) / (1000 * 60 * 60 * 24),\\par\n    );\\par\n  \\}\\par\n\\par\n  const correctionFactors = \\{\\par\n    50: 1.03,\\par\n    60: 1.06,\\par\n    80: 1.18,\\par\n    100: 1.24,\\par\n    120: 1.34,\\par\n  \\};\\par\n\\par\n  const calculatedSpecimens = specimens.map((s) => \\{\\par\n    const load = parseFloat(s.load || 0);\\par\n    const strength = area ? (load * 1000) / area : 0;\\par\n    const correctedStrength = strength * (correctionFactors[thickness] || 1);\\par\n\\par\n    return \\{\\par\n      ...s,\\par\n      strength: Number(strength.toFixed(2)),\\par\n      correctedStrength: Number(correctedStrength.toFixed(2)),\\par\n    \\};\\par\n  \\});\\par\n\\par\n  const correctedStrengthValues = calculatedSpecimens\\par\n    .map((s) => s.correctedStrength)\\par\n    .filter((v) => v > 0);\\par\n\\par\n  const avgCorrectedStrength =\\par\n    correctedStrengthValues.length > 0\\par\n      ? correctedStrengthValues.reduce((a, b) => a + b, 0) / correctedStrengthValues.length\\par\n      : 0;\\par\n\\par\n  const formattedValue = avgCorrectedStrength.toFi